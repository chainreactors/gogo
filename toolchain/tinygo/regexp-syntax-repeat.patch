 }
+
+func (c *compiler) repeat(sub *Regexp, min, max int, nongreedy bool) frag {
+	switch {
+	case min == 0 && max == 0:
+		return c.nop()
+	case max == -1:
+		switch min {
+		case 0:
+			return c.star(c.compile(sub), nongreedy)
+		case 1:
+			return c.plus(c.compile(sub), nongreedy)
+		}
+
+		var prefix frag
+		for i := 0; i < min-1; i++ {
+			next := c.compile(sub)
+			if i == 0 {
+				prefix = next
+			} else {
+				prefix = c.cat(prefix, next)
+			}
+		}
+		return c.cat(prefix, c.plus(c.compile(sub), nongreedy))
+	case min == 1 && max == 1:
+		return c.compile(sub)
+	case max > min:
+		var prefix frag
+		hasPrefix := false
+		for i := 0; i < min; i++ {
+			next := c.compile(sub)
+			if !hasPrefix {
+				prefix = next
+				hasPrefix = true
+			} else {
+				prefix = c.cat(prefix, next)
+			}
+		}
+
+		suffix := c.quest(c.compile(sub), nongreedy)
+		for i := min + 1; i < max; i++ {
+			suffix = c.quest(c.cat(c.compile(sub), suffix), nongreedy)
+		}
+		if hasPrefix {
+			return c.cat(prefix, suffix)
+		}
+		return suffix
+	default:
+		return c.fail()
+	}
+}
 
 // loop returns the fragment for the main loop of a plus or star.
 // For plus, it can be used after changing the entry to f1.i.
